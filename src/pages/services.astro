---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Services & Preise – Stephan Schmied Hair & Make-up Artist Berlin"
  description="Bridal Make-up, Events, Editorial, Grooming und Corporate Workshops. Transparente Preise für professionelle Hair & Make-up Services in Berlin und deutschlandweit."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="label">Leistungen</span>
      <h1>Services &amp; Preise</h1>
      <p>Für jeden Anlass der perfekte Look</p>
    </div>
  </section>

  <!-- ─── Bridal ─── -->
  <section class="section" id="bridal">
    <div class="container">
      <div class="fade-in">
        <span class="label">Hochzeit</span>
        <h2 class="section-title">Bridal</h2>
        <div class="divider"></div>
        <p style="max-width:55ch">Von der ersten Anfrage bis zum letzten Tanz – ich begleite dich durch deinen schönsten Tag mit professionellem Hair & Make-up, das hält und strahlt.</p>
      </div>

      <div class="pricing-grid">
        <!-- Classic -->
        <div class="pricing-card fade-in">
          <h3>Classic</h3>
          <div class="pricing-price">650 – 850 <span>EUR</span></div>
          <ul class="pricing-features">
            <li>Braut-Make-up am Hochzeitstag</li>
            <li>Professionelles Haarstyling</li>
            <li>Probetermin inklusive</li>
            <li>Anfahrt innerhalb Berlins</li>
            <li>Einzelne Wimpern</li>
          </ul>
          <a href="/contact?anlass=Hochzeit" class="btn btn-outline">Anfragen</a>
        </div>

        <!-- Premium -->
        <div class="pricing-card featured fade-in delay-1">
          <span class="badge">Empfohlen</span>
          <h3>Premium</h3>
          <div class="pricing-price">1.200 – 1.500 <span>EUR</span></div>
          <ul class="pricing-features">
            <li>Alles aus Classic</li>
            <li>2 Begleitpersonen inklusive</li>
            <li>Touchup-Kit zum Mitnehmen</li>
            <li>4 Stunden Begleitung am Hochzeitstag</li>
          </ul>
          <a href="/contact?anlass=Hochzeit" class="btn btn-gold">Anfragen</a>
        </div>

        <!-- Luxe -->
        <div class="pricing-card fade-in delay-2">
          <h3>Luxe</h3>
          <div class="pricing-price">2.000 – 2.500 <span>EUR</span></div>
          <ul class="pricing-features">
            <li>Alles aus Premium</li>
            <li>Komplette Bridal Party (bis 5 Personen)</li>
            <li>2 Probetermine</li>
            <li>Ganztägige Begleitung</li>
            <li>Emergency Kit</li>
          </ul>
          <a href="/contact?anlass=Hochzeit" class="btn btn-outline">Anfragen</a>
        </div>
      </div>

      <!-- Extras -->
      <div class="extras-box fade-in mt-lg">
        <h3>Zusatzleistungen</h3>
        <ul class="extras-list">
          <li><span>Bräutigam-Grooming</span><span>+ 80 – 120 EUR</span></li>
          <li><span>Einzelne Begleitperson</span><span>+ 120 – 180 EUR</span></li>
          <li><span>Destination Wedding (Reisepauschale)</span><span>+ 300 – 500 EUR</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ─── Events & Editorial ─── -->
  <section class="section" id="editorial" style="background:#fff">
    <div class="container">
      <div class="service-detail-grid">
        <div class="fade-in">
          <span class="label">Shootings &amp; Events</span>
          <h2 class="section-title">Events &amp; Editorial</h2>
          <div class="divider"></div>
          <div class="pricing-price" style="margin-bottom:1rem">800 – 1.500 <span style="font-family:var(--font-body);font-size:0.9rem;color:var(--color-secondary)">EUR / Tag</span></div>
          <p>Für Agenturen, Produktionsfirmen, Magazine und private Events. Die Tagesgage beinhaltet:</p>
          <ul class="service-list">
            <li>Full-Day-Rate (bis 10 Stunden)</li>
            <li>Eigenes professionelles Equipment</li>
            <li>Prep & Clean-up</li>
            <li>Koordination mit Fotografie &amp; Art Direction</li>
          </ul>
          <p class="mt-sm secondary-text">Halbtagessatz auf Anfrage. Für internationale Produktionen Reisepauschale zusätzlich.</p>
          <a href="/contact?anlass=Shooting" class="btn btn-outline mt-md">Anfragen</a>
        </div>
        <div class="fade-in delay-1">
          <img
            src="https://placehold.co/600x700/4A4A4A/FAFAF8?text=Editorial"
            alt="Editorial Make-up"
            width="600" height="700"
            loading="lazy"
            style="width:100%;object-fit:cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Grooming ─── -->
  <section class="section" id="grooming">
    <div class="container">
      <div class="service-detail-grid reverse">
        <div class="fade-in delay-1">
          <img
            src="https://placehold.co/600x500/1A1A1A/C9A96E?text=Grooming"
            alt="Männer Grooming"
            width="600" height="500"
            loading="lazy"
            style="width:100%;object-fit:cover"
          />
        </div>
        <div class="fade-in">
          <span class="label">Für Männer</span>
          <h2 class="section-title">Grooming</h2>
          <div class="divider"></div>
          <p>Männer-Styling für Events, Shootings, Business-Portraits und Red Carpet. Natürlich und überzeugend.</p>
          <ul class="service-list mt-sm">
            <li>Business-Portrait: 150 – 250 EUR</li>
            <li>Event-Styling: 200 – 350 EUR</li>
            <li>Editorial / Shooting: Tagesgage</li>
          </ul>
          <a href="/contact?anlass=Event" class="btn btn-outline mt-md">Anfragen</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Corporate ─── -->
  <section class="section" id="corporate" style="background:#fff">
    <div class="container">
      <div class="fade-in text-center" style="max-width:700px;margin:0 auto">
        <span class="label">Für Unternehmen</span>
        <h2 class="section-title">Corporate</h2>
        <div class="divider" style="margin:1rem auto"></div>
        <p>Team-Events und Workshops für Unternehmen. Ob "Business Look" für das Jahres-Meeting oder "Self-Care Day" als Team-Event – ich komme zu Ihnen.</p>
        <div class="corporate-offers mt-md">
          <div class="corporate-card">
            <h3>Business Look</h3>
            <p>Professionelles Make-up &amp; Styling für Ihr Team. Konferenzen, Präsentationen, Unternehmensfotos.</p>
          </div>
          <div class="corporate-card">
            <h3>Self-Care Day</h3>
            <p>Ein unvergessliches Team-Event: Workshops, individuelle Beratung und gemeinsames Styling-Erlebnis.</p>
          </div>
        </div>
        <p class="mt-md" style="color:var(--color-gold);font-family:var(--font-heading);font-size:1.1rem">Preis auf Anfrage</p>
        <a href="/contact?anlass=Corporate" class="btn btn-outline mt-sm">Anfragen</a>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="section" id="faq">
    <div class="container">
      <div class="fade-in text-center">
        <span class="label">Häufige Fragen</span>
        <h2 class="section-title">FAQ</h2>
      </div>
      <div class="faq-list mt-md" style="max-width:750px;margin-top:var(--sp-md)">

        <details class="faq-item fade-in">
          <summary>Wann sollte ich meinen Hochzeitstermin buchen?</summary>
          <p class="faq-body">So früh wie möglich – idealerweise 12 bis 18 Monate im Voraus. Beliebte Sommerwochenenden in Berlin und Brandenburg sind schnell vergeben. Nach der Buchung ist dein Termin garantiert reserviert.</p>
        </details>

        <details class="faq-item fade-in">
          <summary>Wie läuft ein Probetermin ab?</summary>
          <p class="faq-body">Der Probetermin dauert ca. 2–3 Stunden. Wir besprechen deine Wünsche, dein Brautkleid und den Stil der Hochzeit. Dann probieren wir verschiedene Looks aus – so hast du am großen Tag keine Überraschungen.</p>
        </details>

        <details class="faq-item fade-in">
          <summary>Welche Produkte verwendest du?</summary>
          <p class="faq-body">Ich arbeite mit hochwertigen Profi-Produkten verschiedener Marken – darunter Charlotte Tilbury, Armani Beauty, NARS und Hourglass. Alle Produkte sind hypoallergen getestet. Bei bekannten Allergien bitte vorab informieren.</p>
        </details>

        <details class="faq-item fade-in">
          <summary>Reist du auch außerhalb Berlins?</summary>
          <p class="faq-body">Ja, ich reise für Destination Weddings und Shootings deutsch- und europaweit. Reisekosten werden nach Aufwand berechnet und vorab transparent kommuniziert.</p>
        </details>

        <details class="faq-item fade-in">
          <summary>Wie lange hält das Make-up?</summary>
          <p class="faq-body">Mit professionellen Techniken und den richtigen Produkten hält das Make-up problemlos 12–16 Stunden – durch Tränen, Tanzen und Umarmungen. Das Touchup-Kit (bei Premium und Luxe inklusive) gibt zusätzliche Sicherheit.</p>
        </details>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <h2>Dein Termin wartet</h2>
    <a href="/contact" class="btn btn-gold">Jetzt anfragen</a>
  </section>
</Layout>

<style>
  .service-detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-lg);
    align-items: center;
  }
  .service-detail-grid.reverse { direction: rtl; }
  .service-detail-grid.reverse > * { direction: ltr; }

  .service-list {
    list-style: none;
    margin-top: 1rem;
  }
  .service-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.92rem;
    color: var(--color-secondary);
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .service-list li::before {
    content: '—';
    color: var(--color-gold);
  }
  .secondary-text { color: var(--color-secondary); font-size: 0.88rem; }

  .extras-box {
    border: 1px solid var(--color-border);
    padding: var(--sp-md);
    background: #fff;
  }
  .extras-box h3 {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
  .extras-list {
    list-style: none;
  }
  .extras-list li {
    display: flex;
    justify-content: space-between;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.9rem;
    color: var(--color-secondary);
  }
  .extras-list li span:last-child { color: var(--color-text); font-weight: 500; }

  .corporate-offers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-sm);
  }
  .corporate-card {
    border: 1px solid var(--color-border);
    padding: 1.5rem;
    text-align: left;
  }
  .corporate-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }
  .corporate-card p {
    font-size: 0.88rem;
    color: var(--color-secondary);
    max-width: none;
  }

  @media (max-width: 768px) {
    .service-detail-grid { grid-template-columns: 1fr; direction: ltr; }
    .corporate-offers { grid-template-columns: 1fr; }
  }
</style>
