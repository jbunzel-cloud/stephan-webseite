---
import Layout from '../layouts/Layout.astro';

const formats = [
  {
    id: 'einzelcoaching',
    title: '1:1 Coaching',
    text: 'Nur du und ich. 2 Stunden in meinem Studio in der Badenschen Straße. Wir analysieren dein Gesicht, finden die Produkte die zu dir passen und ich zeige dir Schritt für Schritt deinen persönlichen Look. Du gehst raus und kannst es selbst.',
    price: 'Ab 249 EUR',
  },
  {
    id: 'gruppenworkshop',
    title: 'Gruppen-Workshop',
    text: '3 Stunden mit maximal 8 Teilnehmerinnen. Themenfokus: Alltags-Make-up, Abend-Look oder Bridal. Praxis, kein Vortrag.',
    price: 'Ab 149 EUR pro Person',
  },
  {
    id: 'online',
    title: 'Online Coaching',
    text: '90 Minuten Live via Zoom. Ich sehe dein Gesicht, du siehst meine Hände. Persönliches Feedback in Echtzeit. Aufzeichnung zum Nachschauen.',
    price: 'Ab 89 EUR',
  },
  {
    id: 'teamevent',
    title: 'Team-Event',
    text: 'Make-up Coaching als Firmenevent. Self-Care Day, Team-Building, Kundinnen-Event. Ich komme zu euch.',
    price: 'Ab 1.500 EUR',
  },
];
---

<Layout
  title="Make-up Coaching – Stephan Schmied Hair & Make-up Artist Berlin"
  description="Lerne Make-up von einem Profi mit fast 40 Jahren Erfahrung. 1:1 Coaching, Gruppen-Workshop und Online Coaching in Berlin. Jetzt buchen."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="label">Coaching &amp; Kurse</span>
      <h1>Make-up Coaching</h1>
      <p>Was ich in vier Jahrzehnten gelernt habe – für dich</p>
    </div>
  </section>

  <!-- ─── Intro ─── -->
  <section class="section coaching-intro">
    <div class="container">
      <div class="coaching-intro-grid fade-in">
        <div class="coaching-intro-img">
          <img
            src="/images/behind-the-scenes/backstage-hair-studio.jpg"
            alt="Stephan Schmied im Studio – Make-up Coaching"
            width="600" height="750"
            loading="lazy"
            style="width:100%;object-fit:cover;display:block"
          />
        </div>
        <div class="coaching-intro-inner">
          <p>Ich habe fast 40 Jahre lang die Gesichter geschminkt, die du aus Magazinen kennst – Kate Moss, Iris Berben, Gwyneth Paltrow, Toni Garn. Jetzt zeige ich dir, wie du das Beste aus deinem eigenen Gesicht herausholst. Meine Coachings sind keine YouTube-Tutorials zum Nachklicken. Sie sind persönlich, individuell und auf dich zugeschnitten – ob im 1:1, in der Gruppe oder online.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Formate ─── -->
  <section class="section" style="background:#fff">
    <div class="container">
      <div class="fade-in text-center">
        <span class="label">Was ich anbiete</span>
        <h2 class="section-title">Formate</h2>
      </div>
      <div class="formats-grid mt-md">
        {formats.map((f, i) => (
          <div class:list={['format-card fade-in', `delay-${i}`]}>
            <h3>{f.title}</h3>
            <p class="format-text">{f.text}</p>
            <div class="format-price">{f.price}</div>
            <a href="/contact?anlass=Coaching" class="btn btn-outline mt-sm">Anfragen</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Testimonials ─── -->
  <section class="section">
    <div class="container">
      <div class="fade-in text-center">
        <span class="label">Was Teilnehmer sagen</span>
        <h2 class="section-title">Stimmen</h2>
      </div>
      <div class="testimonials-grid mt-md" style="max-width:800px;margin-left:auto;margin-right:auto;margin-top:var(--sp-md)">
        <div class="testimonial fade-in">
          <blockquote>"Das Coaching war absolut beeindruckend. Stephan teilt sein Wissen großzügig und erklärt jeden Schritt verständlich. Ich habe mehr gelernt als in jedem Online-Tutorial."</blockquote>
          <cite>— Sabine M., Make-up Enthusiastin, Hamburg</cite>
        </div>
        <div class="testimonial fade-in delay-1">
          <blockquote>"Als Berufseinsteigerin war das 1:1 Coaching ein Wendepunkt für mich. Die Technik, die Atmosphäre, das direkte Feedback – unbezahlbar."</blockquote>
          <cite>— Lena K., Auszubildende Make-up Artistin, Berlin</cite>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="cta-section fade-in">
    <h2>Bereit für dein Coaching?</h2>
    <a href="/contact?anlass=Coaching" class="btn btn-gold">Jetzt anfragen</a>
  </section>
</Layout>

<style>
  .formats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .format-card {
    border: 1px solid var(--color-border);
    padding: 2.5rem var(--sp-md);
    transition: box-shadow var(--transition);
    display: flex;
    flex-direction: column;
  }
  .format-card:hover { box-shadow: 0 8px 40px rgba(0,0,0,0.08); }
  .format-card h3 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .format-text {
    font-size: 0.92rem;
    color: var(--color-secondary);
    line-height: 1.75;
    flex: 1;
    max-width: none;
  }
  .format-price {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    color: var(--color-text);
    margin-top: 1.25rem;
  }

  .coaching-intro { background: #fff; }
  .coaching-intro-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: var(--sp-lg);
    align-items: center;
  }
  .coaching-intro-inner {
    max-width: 600px;
  }
  .coaching-intro-inner p {
    font-size: 1.05rem;
    color: var(--color-secondary);
    line-height: 1.8;
    max-width: none;
  }
  @media (max-width: 768px) {
    .coaching-intro-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .formats-grid { grid-template-columns: 1fr; }
  }
</style>
