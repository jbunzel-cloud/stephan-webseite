---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blog';

export function getStaticPaths() {
  return blogPosts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('de-DE', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
}

const currentIndex = blogPosts.findIndex(p => p.slug === post.slug);
const related = blogPosts.filter((_, i) => i !== currentIndex).slice(0, 3);
---

<Layout
  title={`${post.title} – Stephan Schmied Blog`}
  description={post.teaser}
  image={post.image}
>
  <!-- Hero -->
  <section class="post-hero">
    <div class="post-hero-bg">
      <img src={post.image} alt={post.title} width="1200" height="600" loading="eager" fetchpriority="high" />
    </div>
    <div class="post-hero-overlay"></div>
    <div class="post-hero-content container">
      <span class="label">{post.category}</span>
      <h1>{post.title}</h1>
      <p class="post-meta">
        <span>{formatDate(post.date)}</span>
        <span>·</span>
        <span>Stephan Schmied</span>
        <span>·</span>
        <span>{post.readTime} Min. Lesezeit</span>
      </p>
    </div>
  </section>

  <!-- Article -->
  <article class="section">
    <div class="container">
      <div class="post-layout">
        <div class="post-content prose fade-in" set:html={post.content} />

        <!-- Share Buttons -->
        <div class="share-box fade-in">
          <p class="share-label">Teilen</p>
          <div class="share-btns">
            <a
              href={`https://www.instagram.com/schmiedsteph`}
              target="_blank" rel="noopener noreferrer"
              class="share-btn"
              aria-label="Auf Instagram teilen"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="5"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
              </svg>
              Instagram
            </a>
            <a
              href={`https://api.whatsapp.com/send?text=${encodeURIComponent(post.title + ' – ' + Astro.url.href)}`}
              target="_blank" rel="noopener noreferrer"
              class="share-btn"
              aria-label="Per WhatsApp teilen"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
              </svg>
              WhatsApp
            </a>
          </div>
        </div>
      </div>

      <!-- Related -->
      <div class="related-section fade-in">
        <h2>Weitere Artikel</h2>
        <div class="blog-grid" style="margin-top:var(--sp-md)">
          {related.map(p => (
            <article class="blog-card">
              <a href={`/blog/${p.slug}`}>
                <div class="blog-card-img-wrap">
                  <img src={p.image} alt={p.title} width="800" height="500" loading="lazy" class="blog-card-img" />
                </div>
                <div class="blog-card-body">
                  <span class="blog-tag">{p.category}</span>
                  <h2>{p.title}</h2>
                  <p class="blog-teaser">{p.teaser}</p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .post-hero {
    position: relative;
    height: 65vh;
    min-height: 440px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .post-hero-bg {
    position: absolute;
    inset: 0;
  }
  .post-hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .post-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 60%);
  }
  .post-hero-content {
    position: relative;
    z-index: 1;
    color: #fff;
    padding-bottom: 4rem;
  }
  .post-hero-content h1 {
    font-size: clamp(2rem, 5vw, 4rem);
    margin: 0.5rem 0 1rem;
  }
  .post-meta {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.6);
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    max-width: none;
  }

  .post-layout {
    max-width: 720px;
    margin: 0 auto;
  }

  /* Prose styles */
  .prose { color: var(--color-secondary); }
  .prose :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    color: var(--color-text);
    margin: 2rem 0 0.75rem;
  }
  .prose :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.8;
    max-width: none;
  }

  /* Share */
  .share-box {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .share-label {
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin-bottom: 0.75rem;
    max-width: none;
  }
  .share-btns { display: flex; gap: 0.75rem; }
  .share-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    font-size: 0.82rem;
    color: var(--color-secondary);
    transition: all var(--transition);
  }
  .share-btn:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  /* Related */
  .related-section { margin-top: 5rem; padding-top: 3rem; border-top: 1px solid var(--color-border); }
  .related-section h2 { font-size: 2rem; margin-bottom: 0; }
</style>
