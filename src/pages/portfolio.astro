  { id: 10, cat: 'Grooming',          title: 'Grooming Editorial',                         alt: 'Grooming Editorial – Styling by Stephan Schmied',                                    credits: 'Styling: Stephan Schmied',                                                   img: '/images/portfolio-grooming/grooming-editorial-01.jpg',            w: 600, h: 750 },
  { id: 11, cat: 'Grooming',          title: 'Grooming Editorial',                         alt: 'Grooming Editorial – Styling by Stephan Schmied',                                    credits: 'Styling: Stephan Schmied',                                                   img: '/images/portfolio-grooming/grooming-editorial-02.jpg',            w: 600, h: 700 },
