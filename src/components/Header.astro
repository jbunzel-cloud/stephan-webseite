---
const navLinks = [
  { href: '/portfolio',     label: 'Portfolio' },
  { href: '/services',      label: 'Services & Preise' },
  { href: '/masterclasses', label: 'Masterclasses' },
  { href: '/about',         label: 'Über mich' },
  { href: '/blog',          label: 'Blog' },
  { href: '/contact',       label: 'Kontakt' },
];
const currentPath = Astro.url.pathname;
---

<header id="site-header">
  <div class="header-inner container">
    <a href="/" class="logo" aria-label="Stephan Schmied – Startseite">
      <span class="logo-name">Stephan Schmied</span>
      <span class="logo-sub">Hair &amp; Make-up Artist</span>
    </a>

    <nav class="main-nav" aria-label="Hauptnavigation">
      <ul>
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button class="hamburger" id="hamburger" aria-label="Menü öffnen" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <ul>
      {navLinks.map(link => (
        <li><a href={link.href} class="mobile-nav-link">{link.label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<style>
  #site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 800;
    transition: background 0.4s ease, border-bottom 0.4s ease;
  }
  #site-header.scrolled {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 2px 20px rgba(0,0,0,0.05);
  }
  #site-header.scrolled .logo-name { color: var(--color-text); }
  #site-header.scrolled .logo-sub  { color: var(--color-secondary); }
  #site-header.scrolled .nav-link  { color: var(--color-text); }
  #site-header.scrolled .hamburger span { background: var(--color-text); }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
  }

  /* Logo */
  .logo { display: flex; flex-direction: column; line-height: 1.2; }
  .logo-name {
    font-family: var(--font-signature);
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: none;
    color: #2C2825;
    transition: color 0.4s;
  }
  .logo-sub {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(44,40,37,0.55);
    transition: color 0.4s;
  }
  .logo.dark-logo .logo-name { color: var(--color-text); }
  .logo.dark-logo .logo-sub  { color: var(--color-secondary); }

  /* Nav */
  .main-nav ul {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }
  .nav-link {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    color: rgba(44,40,37,0.75);
    position: relative;
    padding-bottom: 2px;
    transition: color var(--transition);
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px; left: 0; right: 0;
    height: 1px;
    background: var(--color-gold);
    transform: scaleX(0);
    transition: transform var(--transition);
  }
  .nav-link:hover::after,
  .nav-link.active::after { transform: scaleX(1); }
  .nav-link.active { color: var(--color-gold); }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 1px;
    background: #2C2825;
    transition: transform 0.3s ease, opacity 0.3s ease, background 0.4s;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  /* Mobile nav */
  .mobile-nav {
    display: none;
    background: var(--color-dark);
    padding: 0 1.5rem 2rem;
  }
  .mobile-nav.open { display: block; }
  .mobile-nav ul   { list-style: none; }
  .mobile-nav-link {
    display: block;
    padding: 0.9rem 0;
    font-size: 1rem;
    color: rgba(255,255,255,0.85);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    font-family: var(--font-heading);
  }

  @media (max-width: 900px) {
    .main-nav  { display: none; }
    .hamburger { display: flex; }
  }
</style>

<script>
  const header   = document.getElementById('site-header')!;
  const hamburger = document.getElementById('hamburger')!;
  const mobileNav = document.getElementById('mobile-nav')!;

  // Scroll → solid header
  function onScroll() {
    if (window.scrollY > 60) {
      header.classList.add('scrolled');
    } else {
      header.classList.remove('scrolled');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu toggle
  hamburger.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('open');
    mobileNav.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileNav.setAttribute('aria-hidden', String(!isOpen));
  });

  // Close mobile nav on link click
  mobileNav.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      hamburger.classList.remove('open');
      mobileNav.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
      mobileNav.setAttribute('aria-hidden', 'true');
    });
  });
</script>
