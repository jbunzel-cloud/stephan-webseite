---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner container">
    <div class="footer-col footer-brand">
      <p class="footer-logo">Stephan Schmied</p>
      <p class="footer-tagline">Hair &amp; Make-up Artist · Berlin</p>
      <p class="footer-address">Badenssche Straße 14, 10715 Berlin</p>
    </div>

    <nav class="footer-col footer-nav" aria-label="Footer-Navigation">
      <p class="footer-heading">Navigation</p>
      <ul>
        <li><a href="/">Startseite</a></li>
        <li><a href="/portfolio">Portfolio</a></li>
        <li><a href="/services">Services & Preise</a></li>
        <li><a href="/masterclasses">Beauty Workshops</a></li>
        <li><a href="/about">Über mich</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact">Kontakt</a></li>
      </ul>
    </nav>

    <div class="footer-col footer-contact">
      <p class="footer-heading">Kontakt &amp; Social</p>
      <a href="tel:+491773238988" class="footer-phone">+49 177 323 8988</a>
      <a href="mailto:stephan@stephanschmied.com" class="footer-email">
        stephan@stephanschmied.com
      </a>
      <div class="footer-social">
        <a href="https://www.instagram.com/schmiedsteph" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="5"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a href="https://wa.me/491773238988" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
        </a>
      </div>
      <!-- Cloudflare Web Analytics – Hier einfügen -->
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>© {year} Stephan Schmied · <a href="/impressum">Impressum</a> · <a href="/datenschutz">Datenschutz</a></p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--color-dark);
    color: rgba(255,255,255,0.75);
    padding-top: var(--sp-lg);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--sp-md);
    padding-bottom: var(--sp-lg);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    color: #fff;
    margin-bottom: 0.5rem;
    max-width: none;
  }
  .footer-tagline {
    font-size: 0.82rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.45);
    max-width: none;
  }
  .footer-address {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.35);
    margin-top: 0.25rem;
    max-width: none;
  }
  .footer-heading {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1rem;
    max-width: none;
  }
  .footer-nav ul { list-style: none; }
  .footer-nav li { margin-bottom: 0.5rem; }
  .footer-nav a {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.65);
    transition: color var(--transition);
  }
  .footer-nav a:hover { color: var(--color-gold); }
  .footer-phone {
    display: block;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.65);
    margin-bottom: 0.5rem;
    transition: color var(--transition);
  }
  .footer-phone:hover { color: var(--color-gold); }
  .footer-email {
    display: block;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.65);
    margin-bottom: 1.25rem;
    transition: color var(--transition);
  }
  .footer-email:hover { color: var(--color-gold); }
  .footer-social {
    display: flex;
    gap: 1rem;
  }
  .footer-social a {
    color: rgba(255,255,255,0.55);
    transition: color var(--transition);
  }
  .footer-social a:hover { color: var(--color-gold); }

  .footer-bottom {
    padding: 1.25rem 0;
  }
  .footer-bottom .container {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .footer-bottom p {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.35);
    max-width: none;
  }
  .footer-bottom a {
    color: rgba(255,255,255,0.35);
    transition: color var(--transition);
  }
  .footer-bottom a:hover { color: var(--color-gold); }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr; }
    .footer-bottom .container { flex-direction: column; align-items: flex-start; }
  }
</style>
